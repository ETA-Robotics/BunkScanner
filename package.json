{
  "name": "bunkscanner-server",
  "version": "1.0.0",
  "description": "BunkScanner backend — receives Opta gateway data, serves web dashboard",
  "main": "Code/server.js",
  "scripts": {
    "start": "node Code/server.js",
    "dev": "node Code/server.js",
    "test": "jest --verbose",
    "test:server": "jest Code/tests/server.test.js --verbose",
    "test:errors": "jest Code/tests/errorHandler.test.js --verbose",
    "test:frontend": "jest Code/tests/frontend.test.js --verbose",
    "test:firmware": "jest Code/tests/firmware.test.js --verbose",
    "test:legacy": "jest Code/test/ --verbose",
    "test:all": "jest --verbose --coverage",
    "test:modbus": "jest Code/test/modbus.test.js --verbose",
    "diagnostic": "node Code/tools/bus-diagnostic.js",
    "diagnostic:health": "node Code/tools/bus-diagnostic.js health",
    "diagnostic:stress": "node Code/tools/bus-diagnostic.js stress",
    "diagnostic:timeline": "node Code/tools/bus-diagnostic.js timeline",
    "diagnostic:power": "node Code/tools/bus-diagnostic.js power",
    "monitor": "node Code/tools/error-monitor.js",
    "monitor:once": "node Code/tools/error-monitor.js --once",
    "monitor:ci": "node Code/tools/error-monitor.js --once --strict --json"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "jsdom": "^29.0.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "coverageDirectory": "Code/coverage"
  }
}
